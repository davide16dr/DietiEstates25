option_settings:
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro
    RootVolumeSize: 20
    RootVolumeType: gp3
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /api/health
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 30

container_commands:
  01_migrate:
    command: "echo 'Database migration handled by application startup'"
    leader_only: true
