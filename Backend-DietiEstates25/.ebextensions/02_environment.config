option_settings:
  aws:elasticbeanstalk:application:environment:
    # ===== DATABASE (RDS PostgreSQL) =====
    DB_URL: "jdbc:postgresql://database-1.c9ucuikq0yr1.eu-south-1.rds.amazonaws.com:5432/postgres"
    DB_USERNAME: "dietiestatesDM"
    # DB_PASSWORD: CARICATA DA AWS SECRETS MANAGER
    
    # ===== SERVER CONFIGURATION =====
    SERVER_PORT: "8080"
    SPRING_PROFILES_ACTIVE: "production"
    
    # ===== CORS (Frontend URL) =====
    CORS_ORIGINS: "https://dietiestates25.amplifyapp.com,https://dietiestates25.com,http://localhost:4200"
    
    # ===== AWS S3 (Solo bucket name, non credenziali!) =====
    AWS_S3_BUCKET: "dietiestates25-images"
    AWS_S3_REGION: "eu-south-1"
    # AWS_ACCESS_KEY_ID: CARICATA DA AWS SECRETS MANAGER
    # AWS_SECRET_ACCESS_KEY: CARICATA DA AWS SECRETS MANAGER
    
    # ===== JPA/HIBERNATE =====
    SPRING_JPA_HIBERNATE_DDL_AUTO: "validate"
    SPRING_JPA_DATABASE_PLATFORM: "org.hibernate.dialect.PostgreSQL12Dialect"
    SPRING_JPA_SHOW_SQL: "false"
    SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE: "10"
    SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE: "5"
    
    # ===== LOGGING =====
    LOGGING_LEVEL_ROOT: "INFO"
    LOGGING_LEVEL_IT_UNINA_DIETIESTATES25: "DEBUG"
    
    # ===== MAIL (per ora disabilitato) =====
    MAIL_ENABLED: "false"
    # MAIL_USERNAME: CARICATA DA AWS SECRETS MANAGER
    # MAIL_PASSWORD: CARICATA DA AWS SECRETS MANAGER
    
    # ===== JAVA MEMORY =====
    JAVA_OPTS: "-Xmx512m -Xms256m -XX:+UseG1GC"

# ===== NOTE IMPORTANTI =====
# 1. Sostituisci "xxxxx" con l'endpoint RDS reale
#    Es: dietiestates25-db.c9akciq32.eu-south-1.rds.amazonaws.com
#
# 2. TUTTE le API KEY SENSIBILI sono in AWS SECRETS MANAGER:
#    - DB_PASSWORD
#    - JWT_SECRET
#    - AWS_ACCESS_KEY_ID
#    - AWS_SECRET_ACCESS_KEY
#    - GOOGLE_MAPS_API_KEY
#    - GOOGLE_CLIENT_ID
#    - GOOGLE_CLIENT_SECRET
#    - GITHUB_CLIENT_ID
#    - GITHUB_CLIENT_SECRET
#    - FACEBOOK_APP_ID
#    - FACEBOOK_APP_SECRET
#    - MAIL_USERNAME
#    - MAIL_PASSWORD
#
# 3. Elastic Beanstalk legge automaticamente da SecretsManagerConfig.java
