# ⚠️ QUESTO È UN FILE TEMPLATE
# Copia questo file come ".env" nella stessa directory e inserisci le tue chiavi API reali
# Il file .env è ignorato da Git per sicurezza

# Google Maps API
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# OAuth - Google
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID

# OAuth - GitHub
GITHUB_CLIENT_ID=YOUR_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_CLIENT_SECRET

# OAuth - Facebook
FACEBOOK_APP_ID=YOUR_APP_ID
FACEBOOK_APP_SECRET=YOUR_APP_SECRET

# JWT (minimo 32 caratteri)
JWT_SECRET=your-very-long-random-jwt-secret-at-least-32-chars

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
